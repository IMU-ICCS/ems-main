<?xml version="1.0" encoding="ASCII"?>
<provider:ProviderModel xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:provider="http://www.paasage.eu/camel/saloon/feature" xmlns:type="http://www.paasage.eu/camel/type" xsi:schemaLocation="http://www.paasage.eu/camel/saloon/feature ../../metamodel/camel.ecore#//paasage/camel/provider http://www.paasage.eu/camel/type ../../metamodel/camel.ecore#//paasage/camel/type">
  <constraints xsi:type="provider:Requires" from="//@rootFeature/@subFeatures.0" to="//@rootFeature/@subFeatures.0">
    <attributeConstraints from="//@rootFeature/@subFeatures.0/@attributes.1" to="//@rootFeature/@subFeatures.0/@attributes.3">
      <fromValue xsi:type="type:EnumerateValue" name="M"/>
      <toValue xsi:type="type:IntValue" value="1"/>
    </attributeConstraints>
    <cardFrom cardinalityMin="1" cardinalityMax="1"/>
    <cardTo cardinalityMin="1" cardinalityMax="1"/>
  </constraints>

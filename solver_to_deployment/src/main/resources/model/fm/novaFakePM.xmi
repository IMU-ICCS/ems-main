    </attributeConstraints>
    <cardFrom cardinalityMin="1" cardinalityMax="1"/>
    <cardTo cardinalityMin="1" cardinalityMax="1"/>
  </constraints>
  <constraints xsi:type="provider:Requires" from="//@rootFeature/@subFeatures.0" to="//@rootFeature/@subFeatures.0">
    <attributeConstraints from="//@rootFeature/@subFeatures.0/@attributes.1" to="//@rootFeature/@subFeatures.0/@attributes.2">
      <fromValue xsi:type="type:EnumerateValue" value="1" name="L"/>
      <toValue xsi:type="type:FloatValue" value="7.5"/>
    </attributeConstraints>
    <cardFrom cardinalityMin="1" cardinalityMax="1"/>
    <cardTo cardinalityMin="1" cardinalityMax="1"/>
  </constraints>
  <constraints xsi:type="provider:Requires" from="//@rootFeature/@subFeatures.0" to="//@rootFeature/@subFeatures.0">
    <attributeConstraints from="//@rootFeature/@subFeatures.0/@attributes.1" to="//@rootFeature/@subFeatures.0/@attributes.4">
      <fromValue xsi:type="type:EnumerateValue" value="1" name="L"/>
      <toValue xsi:type="type:IntValue" value="32"/>
    </attributeConstraints>
    <cardFrom cardinalityMin="1" cardinalityMax="1"/>
    <cardTo cardinalityMin="1" cardinalityMax="1"/>
  </constraints>
  <constraints xsi:type="provider:Requires" from="//@rootFeature/@subFeatures.0" to="//@rootFeature/@subFeatures.0">
    <attributeConstraints from="//@rootFeature/@subFeatures.0/@attributes.1" to="//@rootFeature/@subFeatures.0/@attributes.3">
      <fromValue xsi:type="type:EnumerateValue" value="2" name="XL"/>
      <toValue xsi:type="type:IntValue" value="4"/>
    </attributeConstraints>
    <cardFrom cardinalityMin="1" cardinalityMax="1"/>
    <cardTo cardinalityMin="1" cardinalityMax="1"/>
  </constraints>
  <constraints xsi:type="provider:Requires" from="//@rootFeature/@subFeatures.0" to="//@rootFeature/@subFeatures.0">
    <attributeConstraints from="//@rootFeature/@subFeatures.0/@attributes.1" to="//@rootFeature/@subFeatures.0/@attributes.2">
      <fromValue xsi:type="type:EnumerateValue" value="2" name="XL"/>
      <toValue xsi:type="type:FloatValue" value="15.0"/>
    </attributeConstraints>
    <cardFrom cardinalityMin="1" cardinalityMax="1"/>
    <cardTo cardinalityMin="1" cardinalityMax="1"/>
  </constraints>
  <constraints xsi:type="provider:Requires" from="//@rootFeature/@subFeatures.0" to="//@rootFeature/@subFeatures.0">
    <attributeConstraints from="//@rootFeature/@subFeatures.0/@attributes.1" to="//@rootFeature/@subFeatures.0/@attributes.4">
      <fromValue xsi:type="type:EnumerateValue" value="2" name="XL"/>
      <toValue xsi:type="type:IntValue" value="80"/>
    </attributeConstraints>
    <cardFrom cardinalityMin="1" cardinalityMax="1"/>
    <cardTo cardinalityMin="1" cardinalityMax="1"/>
  </constraints>
  <constraints xsi:type="provider:Requires" from="//@rootFeature/@subFeatures.0" to="//@rootFeature/@subFeatures.0">
    <attributeConstraints from="//@rootFeature/@subFeatures.0/@attributes.1" to="//@rootFeature/@subFeatures.0/@attributes.3">
      <fromValue xsi:type="type:EnumerateValue" value="3" name="XXL"/>
      <toValue xsi:type="type:IntValue" value="8"/>
    </attributeConstraints>
    <cardFrom cardinalityMin="1" cardinalityMax="1"/>
    <cardTo cardinalityMin="1" cardinalityMax="1"/>
  </constraints>
  <constraints xsi:type="provider:Requires" from="//@rootFeature/@subFeatures.0" to="//@rootFeature/@subFeatures.0">
    <attributeConstraints from="//@rootFeature/@subFeatures.0/@attributes.1" to="//@rootFeature/@subFeatures.0/@attributes.2">
      <fromValue xsi:type="type:EnumerateValue" value="1" name="XXL"/>
      <toValue xsi:type="type:FloatValue" value="30.0"/>
    </attributeConstraints>
    <cardFrom cardinalityMin="1" cardinalityMax="1"/>
    <cardTo cardinalityMin="1" cardinalityMax="1"/>

<?xml version="1.0" encoding="ASCII"?>
<featuremodel:FeatureModel
    xmi:version="2.0"
    xmlns:xmi="http://www.omg.org/XMI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:featuremodel="http://fr.saloon.model.featuremodel"
    xmlns:type="http://fr.saloon.model.type"
    xsi:schemaLocation="http://fr.saloon.model.featuremodel ../../metamodel/FeatureModel.ecore http://fr.saloon.model.type ../../metamodel/Type.ecore">
  <constraints
      xsi:type="featuremodel:Requires"
      from="//@rootFeature/@subFeatures.0"
      to="//@rootFeature/@subFeatures.0">
    <attributeConstraints
        from="//@rootFeature/@subFeatures.0/@attributes.1"
        to="//@rootFeature/@subFeatures.0/@attributes.3"
        fromValue="//@rootFeature/@subFeatures.0/@attributes.1/@value/@values.0"
        toValue="//@rootFeature/@subFeatures.0/@attributes.3/@value/@values.0"/>
    <cardFrom
        cardinalityMin="1"
        cardinalityMax="1"/>
    <cardTo
        cardinalityMin="1"
        cardinalityMax="1"/>
  </constraints>
  <constraints
      xsi:type="featuremodel:Requires"
      from="//@rootFeature/@subFeatures.0"
      to="//@rootFeature/@subFeatures.0">
    <attributeConstraints
        from="//@rootFeature/@subFeatures.0/@attributes.1"
        to="//@rootFeature/@subFeatures.0/@attributes.2"
        fromValue="//@rootFeature/@subFeatures.0/@attributes.1/@value/@values.0"
        toValue="//@rootFeature/@subFeatures.0/@attributes.2/@value/@values.0"/>
    <cardFrom
        cardinalityMin="1"
        cardinalityMax="1"/>
    <cardTo
        cardinalityMin="1"
        cardinalityMax="1"/>
  </constraints>
  <constraints
      xsi:type="featuremodel:Requires"
      from="//@rootFeature/@subFeatures.0"
      to="//@rootFeature/@subFeatures.0">
    <attributeConstraints
        from="//@rootFeature/@subFeatures.0/@attributes.1"
        to="//@rootFeature/@subFeatures.0/@attributes.4"
        fromValue="//@rootFeature/@subFeatures.0/@attributes.1/@value/@values.0"
        toValue="//@rootFeature/@subFeatures.0/@attributes.4/@value/@values.0"/>
    <cardFrom
        cardinalityMin="1"
        cardinalityMax="1"/>
    <cardTo
        cardinalityMin="1"
        cardinalityMax="1"/>
  </constraints>
  <constraints
      xsi:type="featuremodel:Requires"
      from="//@rootFeature/@subFeatures.0"
      to="//@rootFeature/@subFeatures.0">
    <attributeConstraints
        from="//@rootFeature/@subFeatures.0/@attributes.1"
        to="//@rootFeature/@subFeatures.0/@attributes.3"
        fromValue="//@rootFeature/@subFeatures.0/@attributes.1/@value/@values.1"
        toValue="//@rootFeature/@subFeatures.0/@attributes.3/@value/@values.1"/>
  </constraints>
  <constraints
      xsi:type="featuremodel:Requires"
      from="//@rootFeature/@subFeatures.0"
      to="//@rootFeature/@subFeatures.0">
    <attributeConstraints
        from="//@rootFeature/@subFeatures.0/@attributes.1"
        to="//@rootFeature/@subFeatures.0/@attributes.2"
        fromValue="//@rootFeature/@subFeatures.0/@attributes.1/@value/@values.1"
        toValue="//@rootFeature/@subFeatures.0/@attributes.2/@value/@values.1"/>
  </constraints>
  <constraints
      xsi:type="featuremodel:Requires"
      from="//@rootFeature/@subFeatures.0"
      to="//@rootFeature/@subFeatures.0">
    <attributeConstraints
        from="//@rootFeature/@subFeatures.0/@attributes.1"
        to="//@rootFeature/@subFeatures.0/@attributes.4"
        fromValue="//@rootFeature/@subFeatures.0/@attributes.1/@value/@values.1"
        toValue="//@rootFeature/@subFeatures.0/@attributes.4/@value/@values.1"/>
  </constraints>
  <constraints
      xsi:type="featuremodel:Requires"
      from="//@rootFeature/@subFeatures.0"
      to="//@rootFeature/@subFeatures.0">
    <attributeConstraints
        from="//@rootFeature/@subFeatures.0/@attributes.1"
        to="//@rootFeature/@subFeatures.0/@attributes.3"
        fromValue="//@rootFeature/@subFeatures.0/@attributes.1/@value/@values.2"
        toValue="//@rootFeature/@subFeatures.0/@attributes.3/@value/@values.2"/>
  </constraints>
  <constraints
      xsi:type="featuremodel:Requires"
      from="//@rootFeature/@subFeatures.0"
      to="//@rootFeature/@subFeatures.0">
    <attributeConstraints
        from="//@rootFeature/@subFeatures.0/@attributes.1"
        to="//@rootFeature/@subFeatures.0/@attributes.2"
        fromValue="//@rootFeature/@subFeatures.0/@attributes.1/@value/@values.2"
        toValue="//@rootFeature/@subFeatures.0/@attributes.2/@value/@values.2"/>
  </constraints>
  <constraints
      xsi:type="featuremodel:Requires"
      from="//@rootFeature/@subFeatures.0"
      to="//@rootFeature/@subFeatures.0">
    <attributeConstraints
        from="//@rootFeature/@subFeatures.0/@attributes.1"
        to="//@rootFeature/@subFeatures.0/@attributes.4"
        fromValue="//@rootFeature/@subFeatures.0/@attributes.1/@value/@values.2"
        toValue="//@rootFeature/@subFeatures.0/@attributes.4/@value/@values.2"/>
  </constraints>
  <constraints
      xsi:type="featuremodel:Requires"
      from="//@rootFeature/@subFeatures.0"
      to="//@rootFeature/@subFeatures.0">
    <attributeConstraints
        from="//@rootFeature/@subFeatures.0/@attributes.1"
        to="//@rootFeature/@subFeatures.0/@attributes.3"
        fromValue="//@rootFeature/@subFeatures.0/@attributes.1/@value/@values.3"
        toValue="//@rootFeature/@subFeatures.0/@attributes.3/@value/@values.3"/>
  </constraints>
  <constraints
      xsi:type="featuremodel:Requires"
      from="//@rootFeature/@subFeatures.0"
      to="//@rootFeature/@subFeatures.0">
    <attributeConstraints
        from="//@rootFeature/@subFeatures.0/@attributes.1"
        to="//@rootFeature/@subFeatures.0/@attributes.2"
        fromValue="//@rootFeature/@subFeatures.0/@attributes.1/@value/@values.3"
        toValue="//@rootFeature/@subFeatures.0/@attributes.2/@value/@values.3"/>
  </constraints>
  <constraints
      xsi:type="featuremodel:Requires"
      from="//@rootFeature/@subFeatures.0"
      to="//@rootFeature/@subFeatures.0">
    <attributeConstraints
        from="//@rootFeature/@subFeatures.0/@attributes.1"
        to="//@rootFeature/@subFeatures.0/@attributes.4"
        fromValue="//@rootFeature/@subFeatures.0/@attributes.1/@value/@values.3"
        toValue="//@rootFeature/@subFeatures.0/@attributes.4/@value/@values.3"/>
  </constraints>
  <rootFeature
      name="Amazon EC2">
    <attributes
        name="deploymentModel">
      <value
          xsi:type="type:StringValue"
          value="Public"/>
    </attributes>
    <attributes
        name="serviceModel">
      <value
          xsi:type="type:StringValue"
          value="IaaS"/>
    </attributes>
    <subFeatures
        name="Virtual Machine">
      <attributes
          name="vmOS">
        <value
            xsi:type="type:EnumerateListValue"
            value="//@rootFeature/@subFeatures.0/@attributes.0/@value/@values.0">
          <values
              name="Ubuntu"/>
          <values
              value="1"
              name="windowsServer"/>
          <values
              value="2"
              name="RedHatEnterpriseLinux"/>
        </value>
      </attributes>
      <attributes
          name="vmSize">
        <value
            xsi:type="type:EnumerateListValue"
            value="//@rootFeature/@subFeatures.0/@attributes.1/@value/@values.0">
          <values
              name="M"/>
          <values
              value="1"
              name="L"/>
          <values
              value="2"
              name="XL"/>
          <values
              value="3"
              name="XXL"/>
        </value>
      </attributes>
      <attributes
          name="vmMemorySize">
        <value
            xsi:type="type:ListValue"
            type="FloatType"
            value="//@rootFeature/@subFeatures.0/@attributes.2/@value/@values.0">
          <values
              xsi:type="type:FloatValue"
              unit="GB"
              value="3.75"/>
          <values
              xsi:type="type:FloatValue"
              unit="GB"
              value="7.5"/>
          <values
              xsi:type="type:FloatValue"
              unit="GB"
              value="15.0"/>
          <values
              xsi:type="type:FloatValue"
              unit="GB"
              value="30.0"/>
        </value>
      </attributes>
      <attributes
          name="vmCpuCores">
        <value
            xsi:type="type:ListValue"
            value="//@rootFeature/@subFeatures.0/@attributes.3/@value/@values.0">
          <values
              xsi:type="type:IntValue"
              unit="Cores"
              value="1"/>
          <values
              xsi:type="type:IntValue"
              unit="Cores"
              value="2"/>
          <values
              xsi:type="type:IntValue"
              unit="Cores"
              value="4"/>
          <values
              xsi:type="type:IntValue"
              unit="Cores"
              value="8"/>
        </value>
      </attributes>
      <attributes
          name="vmStorage">
        <value
            xsi:type="type:ListValue"
            value="//@rootFeature/@subFeatures.0/@attributes.4/@value/@values.0">
          <values
              xsi:type="type:IntValue"
              unit="GB"
              value="4"/>
          <values
              xsi:type="type:IntValue"
              unit="GB"
              value="32"/>
          <values
              xsi:type="type:IntValue"
              unit="GB"
              value="80"/>
          <values
              xsi:type="type:IntValue"
              unit="GB"
              value="160"/>
        </value>
      </attributes>
      <featureCardinality
          cardinalityMin="1"
          cardinalityMax="-1"/>
    </subFeatures>
    <subFeatures
        name="Services">
      <subFeatures
          name="Amazon VPC">
        <subFeatures
            name="VPN Connection">
          <featureCardinality
              cardinalityMax="1"/>
        </subFeatures>
        <featureCardinality
            cardinalityMin="1"
            cardinalityMax="5"/>
      </subFeatures>
      <featureCardinality
          cardinalityMax="1"/>
    </subFeatures>
    <subFeatures
        xsi:type="featuremodel:Exclusive"
        name="Location">
      <featureCardinality
          cardinalityMin="1"
          cardinalityMax="1"/>
      <groupCardinality
          cardinalityMin="1"
          cardinalityMax="1"/>
      <variants
          name="EU">
        <featureCardinality
            cardinalityMax="1"/>
      </variants>
      <variants
          name="US East">
        <featureCardinality
            cardinalityMax="1"/>
      </variants>
    </subFeatures>
    <subFeatures
        name="Pricing Model">
      <subFeatures
          name="Per Hour">
        <featureCardinality
            cardinalityMax="1"/>
      </subFeatures>
      <featureCardinality
          cardinalityMax="1"/>
    </subFeatures>
    <featureCardinality
        cardinalityMin="1"
        cardinalityMax="1"
        value="1"/>
  </rootFeature>
</featuremodel:FeatureModel>

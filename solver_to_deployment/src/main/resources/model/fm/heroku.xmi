        <featureCardinality
            cardinalityMax="1"/>
        <variants
            xsi:type="featuremodel:Alternative"
            name="SQL">
          <featureCardinality
              cardinalityMax="1"/>
          <variants
              name="Heroku Postgres">
            <attributes
                name="herokuPostgresDiskSize">
              <value
                  xsi:type="type:ListValue"
                  value="#//@rootFeature/@subFeatures.3/@variants.0/@variants.0/@variants.0/@attributes.0/@value/@values.3">
                <values
                    xsi:type="type:IntValue"
                    unit="MB"
                    value="1048576"/>
                <values
                    xsi:type="type:IntValue"
                    unit="MB"
                    value="524888"/>
                <values
                    xsi:type="type:IntValue"
                    unit="MB"
                    value="262144"/>
                <values
                    xsi:type="type:IntValue"
                    unit="MB"
                    value="65536"/>
              </value>
            </attributes>
            <featureCardinality
                cardinalityMax="1"/>
          </variants>
          <variants
              name="Treasure Data">
            <attributes
                name="TreasureDataDiskSize">
              <value
                  xsi:type="type:IntValue"
                  unit="MB"
                  value="153600"/>
            </attributes>
            <featureCardinality
                cardinalityMax="1"/>
          </variants>
          <variants
              name="PG Backpups">
            <attributes
                name="PGBackupsDiskSize">
              <value
                  xsi:type="type:IntValue"
                  unit="MB"
                  value="20480"/>
            </attributes>
            <featureCardinality
                cardinalityMax="1"/>
          </variants>
          <variants
              name="ClearDB">
            <attributes
                name="ClearDBDiskSize">
              <value
                  xsi:type="type:ListValue"
                  value="#//@rootFeature/@subFeatures.3/@variants.0/@variants.0/@variants.3/@attributes.0/@value/@values.3">
                <values
                    xsi:type="type:IntValue"
                    unit="MB"
                    value="10240"/>
                <values
                    xsi:type="type:IntValue"
                    unit="MB"
                    value="5120"/>
                <values
                    xsi:type="type:IntValue"
                    unit="MB"
                    value="1024"/>
                <values
                    xsi:type="type:IntValue"
                    unit="MB"
                    value="5"/>
              </value>
            </attributes>
            <featureCardinality
                cardinalityMax="1"/>
          </variants>
          <variants
              name="Amazon RDS">
            <featureCardinality
                cardinalityMax="1"/>
          </variants>
        </variants>
        <variants
            xsi:type="featuremodel:Alternative"
            name="NoSQL">
          <featureCardinality
              cardinalityMax="1"/>
          <variants
              xsi:type="featuremodel:Alternative"
              name="Key-Value Store">
            <featureCardinality
                cardinalityMax="1"/>
            <variants

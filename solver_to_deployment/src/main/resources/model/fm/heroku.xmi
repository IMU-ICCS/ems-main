                    unit="MB"
                    value="750"/>
              </attributes>
              <featureCardinality
                  cardinalityMax="1"/>
            </variants>
            <variants
                name="IronCache">
              <attributes
                  name="IronCacheDiskSize">
                <value
                    xsi:type="type:ListValue"
                    value="#//@rootFeature/@subFeatures.3/@variants.0/@variants.1/@variants.0/@variants.1/@attributes.0/@value/@values.3">
                  <values
                      xsi:type="type:IntValue"
                      unit="MB"
                      value="20480"/>
                  <values
                      xsi:type="type:IntValue"
                      unit="MB"
                      value="5120"/>
                  <values
                      xsi:type="type:IntValue"
                      unit="MB"
                      value="1024"/>
                  <values
                      xsi:type="type:IntValue"
                      unit="MB"
                      value="100"/>
                </value>
              </attributes>
              <featureCardinality
                  cardinalityMax="1"/>
            </variants>
          </variants>
          <variants
              xsi:type="featuremodel:Alternative"
              name="Document Store">
            <featureCardinality
                cardinalityMax="1"/>
            <variants
                name="MongoLab">
              <attributes
                  name="mongoLabDiskSize">
                <value
                    xsi:type="type:ListValue"
                    value="#//@rootFeature/@subFeatures.3/@variants.0/@variants.1/@variants.1/@variants.0/@attributes.0/@value/@values.3">
                  <values
                      xsi:type="type:IntValue"
                      unit="MB"
                      value="61440"/>
                  <values
                      xsi:type="type:IntValue"
                      unit="MB"
                      value="8192"/>
                  <values
                      xsi:type="type:IntValue"
                      unit="MB"
                      value="2048"/>
                  <values
                      xsi:type="type:IntValue"
                      unit="MB"
                      value="496"/>
                </value>
              </attributes>
              <featureCardinality
                  cardinalityMax="1"/>
            </variants>
            <variants
                name="Cloudant">
              <attributes
                  name="cloudantDiskSize">
                <value
                    xsi:type="type:ListValue"
                    value="#//@rootFeature/@subFeatures.3/@variants.0/@variants.1/@variants.1/@variants.1/@attributes.0/@value/@values.5">
                  <values
                      xsi:type="type:IntValue"
                      unit="MB"
                      value="25600"/>
                  <values
                      xsi:type="type:IntValue"
                      unit="MB"
                      value="15360"/>
                  <values
                      xsi:type="type:IntValue"
                      unit="MB"
                      value="10240"/>
                  <values
                      xsi:type="type:IntValue"
                      unit="MB"
                      value="5120"/>
                  <values
                      xsi:type="type:IntValue"
                      unit="MB"
                      value="2048"/>
                  <values
                      xsi:type="type:IntValue"
                      unit="MB"
                      value="1024"/>
                </value>
              </attributes>
              <featureCardinality
                  cardinalityMax="1"/>
            </variants>
            <variants
                name="MongoHQ">
              <attributes
                  name="mongoHQDiskSize">
                <value
                    xsi:type="type:IntValue"
                    unit="MB"
                    value="512"/>
              </attributes>
              <featureCardinality
                  cardinalityMax="1"/>
            </variants>
          </variants>
        </variants>
      </variants>
      <variants
          xsi:type="featuremodel:Alternative"
          name="Search Engine">
        <featureCardinality
            cardinalityMax="1"/>
        <variants
            name="Web Solr">
          <featureCardinality
              cardinalityMax="1"/>
        </variants>
        <variants
            name="Flying Sphinx">
          <featureCardinality
              cardinalityMax="1"/>
        </variants>
        <variants
            name="Bonsai Elasticsearch">
          <featureCardinality
              cardinalityMax="1"/>
        </variants>
        <variants
            name="Found Elastic Search">
          <featureCardinality
              cardinalityMax="1"/>
        </variants>
      </variants>
      <variants
          xsi:type="featuremodel:Alternative"
          name="Caching">
        <featureCardinality
            cardinalityMax="1"/>
        <variants
            name="Cachely">
          <featureCardinality
              cardinalityMax="1"/>
        </variants>
        <variants
            name="MemCachier">
          <featureCardinality
              cardinalityMax="1"/>
        </variants>
        <variants
            name="IronCache">
          <featureCardinality
              cardinalityMax="1"/>
        </variants>
      </variants>
    </subFeatures>
    <subFeatures
        xsi:type="featuremodel:Exclusive"
        name="Location">
      <featureCardinality
          cardinalityMax="1"/>
      <groupCardinality
          cardinalityMax="1"/>
      <variants
          name="US">
        <featureCardinality
            cardinalityMax="1"/>
      </variants>
      <variants
          name="EU">
        <featureCardinality
            cardinalityMax="1"/>
      </variants>
    </subFeatures>
    <featureCardinality
        cardinalityMin="1"
        cardinalityMax="1"/>
  </rootFeature>
</featuremodel:FeatureModel>

<?xml version="1.0" encoding="ASCII"?>
<featuremodel:FeatureModel
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:featuremodel="http://fr.saloon.model.featuremodel"
    xmlns:type="http://fr.saloon.model.type"
    xsi:schemaLocation="http://fr.saloon.model.featuremodel ../../metamodel/FeatureModel.ecore http://fr.saloon.model.type ../../metamodel/Type.ecore">
  <constraints
      xsi:type="featuremodel:Requires"
      from="#//@rootFeature/@subFeatures.2"
      to="#//@rootFeature/@subFeatures.2">
    <attributeConstraints
        from="#//@rootFeature/@subFeatures.2/@attributes.0"
        to="#//@rootFeature/@subFeatures.2/@attributes.2"
        fromValue="#//@rootFeature/@subFeatures.2/@attributes.0/@value/@values.0"
        toValue="#//@rootFeature/@subFeatures.3/@variants.0/@variants.1/@variants.1/@variants.2/@attributes.0/@value"/>
    <cardFrom
        cardinalityMin="1"
        cardinalityMax="1"/>
  </constraints>
  <constraints
      xsi:type="featuremodel:Requires"
      from="#//@rootFeature/@subFeatures.2"
      to="#//@rootFeature/@subFeatures.2">
    <attributeConstraints
        from="#//@rootFeature/@subFeatures.2/@attributes.0"
        to="#//@rootFeature/@subFeatures.2/@attributes.2"
        fromValue="#//@rootFeature/@subFeatures.2/@attributes.0/@value/@values.1"
        toValue="#//@rootFeature/@subFeatures.3/@variants.0/@variants.1/@variants.1/@variants.1/@attributes.0/@value/@values.5"/>
    <cardFrom
        cardinalityMin="1"
        cardinalityMax="1"/>
  </constraints>
  <constraints
      xsi:type="featuremodel:Implies"
      from="#//@rootFeature/@subFeatures.1/@variants.0"
      to="#//@rootFeature/@subFeatures.0/@variants.1"/>
  <constraints
      xsi:type="featuremodel:Implies"
      from="#//@rootFeature/@subFeatures.1/@variants.2"
      to="#//@rootFeature/@subFeatures.0/@variants.1"/>
  <constraints
      xsi:type="featuremodel:Implies"
      from="#//@rootFeature/@subFeatures.1/@variants.3"
      to="#//@rootFeature/@subFeatures.0/@variants.2"/>
  <constraints
      xsi:type="featuremodel:Implies"
      from="#//@rootFeature/@subFeatures.1/@variants.1"
      to="#//@rootFeature/@subFeatures.0/@variants.2"/>
  <rootFeature
      name="Heroku">
    <subFeatures
        xsi:type="featuremodel:Exclusive"
        name="Language">
      <featureCardinality
          cardinalityMax="1"/>
      <variants
          name="Clojure">
        <featureCardinality
            cardinalityMax="1"/>
      </variants>
      <variants
          name="Java">
        <featureCardinality
            cardinalityMax="1"/>
      </variants>
      <variants
          name="Ruby">
        <featureCardinality
            cardinalityMax="1"/>
      </variants>
      <variants
          name="Scala">
        <featureCardinality
            cardinalityMax="1"/>
      </variants>
      <variants
          name="Python">
        <featureCardinality
            cardinalityMax="1"/>
      </variants>
      <variants
          name="Javascript">
        <featureCardinality
            cardinalityMax="1"/>
      </variants>
    </subFeatures>
    <subFeatures
        xsi:type="featuremodel:Alternative"
        name="Framework">
      <featureCardinality
          cardinalityMax="1"/>
      <variants
          name="Spring">
        <featureCardinality
            cardinalityMax="1"/>
      </variants>
      <variants
          name="Rails">
        <featureCardinality
            cardinalityMax="1"/>
      </variants>
      <variants
          name="Play">
        <featureCardinality
            cardinalityMax="1"/>
      </variants>
      <variants
          name="Node.js">
        <featureCardinality
            cardinalityMax="1"/>
      </variants>
    </subFeatures>
    <subFeatures
        name="Dyno">
      <attributes
          name="dynoSize">
        <value
            xsi:type="type:ListValue"
            type="StringType"
            value="#//@rootFeature/@subFeatures.2/@attributes.0/@value/@values.0">
          <values
              xsi:type="type:StringValue"
              value="1X"/>
          <values
              xsi:type="type:StringValue"
              value="2X"/>
        </value>
      </attributes>
      <attributes
          name="kind">
        <value
            xsi:type="type:ListValue"
            type="StringType"
            value="#//@rootFeature/@subFeatures.2/@attributes.1/@value/@values.0">
          <values
              xsi:type="type:StringValue"
              value="Web"/>
          <values
              xsi:type="type:StringValue"
              value="Worker"/>
        </value>
      </attributes>
      <attributes
          name="dynoMemorySize">
        <value
            xsi:type="type:ListValue"
            value="#//@rootFeature/@subFeatures.3/@variants.0/@variants.1/@variants.1/@variants.2/@attributes.0/@value">
          <values
              xsi:type="type:IntValue"
              unit="MB"
              value="512"/>
          <values
              xsi:type="type:IntValue"
              unit="MB"
              value="1024"/>
        </value>
      </attributes>
      <attributes
          name="cpuFrequency">
        <value
            xsi:type="type:FloatValue"
            unit="GHz"
            value="2.67"/>
      </attributes>
      <attributes
          name="slugSize">
        <value
            xsi:type="type:IntValue"
            unit="MB"
            value="200"/>
      </attributes>
      <featureCardinality
          cardinalityMax="150"/>
    </subFeatures>
    <subFeatures

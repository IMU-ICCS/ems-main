						<argument>-X</argument>
						<argument>myproject:dist</argument>
					</arguments>-->
					<!--<systemProperties>
						<systemProperty>
							<key>myproperty</key>
							<value>myvalue</value>
						</systemProperty>
					</systemProperties>-->
				</configuration>
			</plugin>
			<!-- IMPORTANT: DON'T USE MAVEN ASSEMBLY PLUGIN for bundling classes. IT INVALIDATES SIGNING OF DEPENDENCY JARS  (esp. BouncyCastleProvider JCE PROVIDER) -->

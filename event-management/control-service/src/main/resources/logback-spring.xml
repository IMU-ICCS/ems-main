<configuration>
	<include resource="org/springframework/boot/logging/logback/base.xml"/>
	
	<!-- XXX: Use this appender for simpler logging messages (only level) during development -->
	<!-- change ref="CONSOLE" to ref-"STDOUT" in the logger entries -->
	<appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
		<layout class="ch.qos.logback.classic.PatternLayout">
			<Pattern>[%-5level] %msg%n</Pattern>
		</layout>
	</appender>
	
	<logger name="root" level="ERROR"> <appender-ref ref="CONSOLE"/> </logger>
	<logger name="org.springframework" level="INFO"> <appender-ref ref="CONSOLE"/> </logger>
	<logger name="eu.melodic.event.control" level="INFO" additivity="false"> <appender-ref ref="CONSOLE"/> </logger>
	<logger name="eu.melodic.event.translate" level="INFO" additivity="false"> <appender-ref ref="CONSOLE"/> </logger>
	<logger name="eu.melodic.event.baguette.server" level="INFO" additivity="false"> <appender-ref ref="CONSOLE"/> </logger>
</configuration>

    <hasInfo href="cdo://repo1/camel#lhttp://www.paasage.eu/camel#VMInfo#2"/>
  </componentInstances>
  <componentInstances xsi:type="deployment:VMInstance" name="SL_Instance" type="//@components.5" hasConfig="//@images.1">

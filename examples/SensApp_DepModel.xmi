    <hasInfo href="cdo://repo1/camel#lhttp://www.paasage.eu/camel#VMInfo#3"/>
  </componentInstances>
  <communicationInstances name="SensApp_to_Admin_Inst" type="//@communications.0" requiredCommunicationInstance="//@componentInstances.4/@requiredCommunicationInstances.0" providedCommunicationInstance="//@componentInstances.1/@providedCommunicationInstances.0"/>
  <communicationInstances name="SensApp_To_MongoDB_Inst" type="//@communications.1" requiredCommunicationInstance="//@componentInstances.1/@requiredCommunicationInstances.0" providedCommunicationInstance="//@componentInstances.2/@providedCommunicationInstances.0"/>
  <hostingInstances name="Admin1_to_JettySC2" providedHostInstance="//@componentInstances.3/@providedHostInstances.0" requiredHostInstance="//@componentInstances.4/@requiredHostInstance" type="//@hostings.0"/>
  <hostingInstances name="JettySC2_to_SL_Inst" providedHostInstance="//@componentInstances.7/@providedHostInstances.0" requiredHostInstance="//@componentInstances.3/@requiredHostInstance" type="//@hostings.4"/>
  <hostingInstances name="JettySC1_to_LL_Inst" providedHostInstance="//@componentInstances.6/@providedHostInstances.0" requiredHostInstance="//@componentInstances.0/@requiredHostInstance" type="//@hostings.2"/>
  <hostingInstances name="MongoDB_to_ML_Inst" providedHostInstance="//@componentInstances.5/@providedHostInstances.0" requiredHostInstance="//@componentInstances.2/@requiredHostInstance" type="//@hostings.3"/>

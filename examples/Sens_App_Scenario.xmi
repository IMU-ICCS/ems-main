          downloadCommand="wget -P ~ http://cloudml.org/scripts/linux/ubuntu/mongoDB/install_mongoDB.sh"
          installCommand="cd ~; sudo bash install_mongoDB.sh"/>
      <providedCommunications
          name="mongoDB"
          owner="//@deploymentModels.0/@components.1"/>
      <requiredHost
          name="MongoDBHostReq"
          owner="//@deploymentModels.0/@components.1"/>
    </components>
    <components

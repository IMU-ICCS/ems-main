  <scalabilityModels>
    <metricTemplates
        name="RAW_EXEC_TIME"
        unit="//@scalabilityModels.0/@units.0"
        property="//@scalabilityModels.0/@properties.0"/>
    <metricTemplates
        name="AVG_EXEC_TIME"
        unit="//@scalabilityModels.0/@units.0"
        property="//@scalabilityModels.0/@properties.0"
        type="COMPOSITE"
        formula="//@scalabilityModels.0/@formulas.0"/>
    <metricTemplates
        name="Storage"
        unit="//@scalabilityModels.0/@units.1"
        layer="IaaS"
        property="//@scalabilityModels.0/@properties.1"/>
    <metrics
        id="RawETMetric1"
        template="//@scalabilityModels.0/@metricTemplates.0"
        sensor="//@scalabilityModels.0/@sensors.0"
        objectBinding="//@scalabilityModels.0/@bindingInstances.0">
      <valueType
          xsi:type="type:Range"
          primitiveType="FloatType">
        <lowerLimit>
          <value
              xsi:type="type:FloatValue"/>
        </lowerLimit>
        <upperLimit>
          <value
              xsi:type="type:PositiveInf"/>
        </upperLimit>
      </valueType>
    </metrics>
    <metrics
        id="AVGETMetric1"
        template="//@scalabilityModels.0/@metricTemplates.1"
        componentMetrics="RawETMetric1"
        objectBinding="//@scalabilityModels.0/@bindingInstances.0">
      <valueType
          xsi:type="type:Range"
          primitiveType="FloatType">
        <lowerLimit>
          <value
              xsi:type="type:FloatValue"/>
        </lowerLimit>
        <upperLimit>
          <value
              xsi:type="type:PositiveInf"/>
        </upperLimit>
      </valueType>
    </metrics>
    <metrics
        id="RawStorageNum"
        template="//@scalabilityModels.0/@metricTemplates.2"
        sensor="//@scalabilityModels.0/@sensors.2"
        objectBinding="//@scalabilityModels.0/@bindingInstances.1">
      <valueType
          xsi:type="type:Range">
        <lowerLimit
            included="true">
          <value
              xsi:type="type:IntValue"
              value="200"/>
        </lowerLimit>
        <upperLimit
            included="true">
          <value
              xsi:type="type:IntValue"
              value="2048"/>
        </upperLimit>
      </valueType>
    </metrics>
    <rules name="AvgETRule"
        event="//@scalabilityModels.0/@events.0"
        actions="//@scalabilityModels.0/@actions.0"/>
    <rules name="StorageViolRule"
        event="//@scalabilityModels.0/@events.1"
        actions="//@scalabilityModels.0/@actions.1"/>
    <events
        xsi:type="scalability:NonFunctionalEvent"
        name="NFAvgETViol"
        metricCondition="//@scalabilityModels.0/@conditions.0"
        isViolation="true"/>
    <events
        xsi:type="scalability:NonFunctionalEvent"
        name="NFRawStorageViol"
        metricCondition="//@scalabilityModels.0/@conditions.1"
        isViolation="true"/>
    <conditions
        xsi:type="scalability:MetricCondition"
        threshold="10.0"
        metric="AVGETMetric1"/>
    <conditions
        xsi:type="scalability:MetricCondition"
        threshold="500.0"
        comparisonOperator="GREATER_EQUAL_THAN"
        metric="RawStorageNum"/>
    <properties
        id="ExecTime"
        name="Execution Time"
        type="MEASURABLE"/>
    <properties
        id="Storage"
        name="Storage"
        type="MEASURABLE"/>
    <actions
        name="VertScaleSensApp"
        type="SCALE_OUT"
        count="1"
        vmInstance="//@deploymentModels.0/@componentInstances.6"
        componentInstance="//@deploymentModels.0/@componentInstances.1"/>
    <actions
        name="HorizScaleMongoDBVM"
        type="SCALE_UP"
        storageUpdate="512"
        vmInstance="//@deploymentModels.0/@componentInstances.5"/>
    <formulas
        function="AVERAGE"
        parameters="//@scalabilityModels.0/@metricTemplates.0"/>
    <bindingInstances
        xsi:type="scalability:MetricApplicationInstanceBinding"
        executionContext="SensAppEC1"/>
    <bindingInstances
        xsi:type="scalability:MetricVMInstanceBinding"
        executionContext="SensAppEC1"
        vmInstance="//@deploymentModels.0/@componentInstances.5"/>
    <sensors

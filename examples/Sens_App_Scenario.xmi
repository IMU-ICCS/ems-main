          installCommand="cd ~; sudo bash install_sensappadmin.sh"
          startCommand="cd ~; sudo bash start_sensappadmin.sh"
          stopCommand="sudo rm -rf /opt/jetty/webapps/SensAppGUI ; sudo service jetty restart"/>

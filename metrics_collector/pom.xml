  </dependency>

	<!-- Zero MQ -->
	<dependency>
 		<groupId>org.zeromq</groupId>
 		<artifactId>jeromq</artifactId>
  		<version>0.3.2</version>
  	</dependency>
  	<!-- Logging -->
  	<dependency>
		<groupId>log4j</groupId>

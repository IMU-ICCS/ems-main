    <groupId>eu.melodic</groupId>
    <artifactId>metrics-collector</artifactId>
    <version>2.0.0-SNAPSHOT</version>

    <name>Upperware - Metrics Collector</name>

    <properties>
        <!--DOCKER plugin properties-->
        <docker.imageName>${docker.repository}melodic/metrics-collector</docker.imageName>
    </properties>


    <build>
        <finalName>${project.artifactId}</finalName>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
            </plugin>
            <plugin>
                <groupId>com.spotify</groupId>
                <artifactId>docker-maven-plugin</artifactId>
            </plugin>
        </plugins>
    </build>
  
  <dependencies>
  <dependency>
		<groupId>org.ow2.paasage.mddb.cdo</groupId>
		<artifactId>client</artifactId>
  </dependency>
	<!--  InfluxDB -->	
	<dependency>
		<groupId>org.influxdb</groupId>
		<artifactId>influxdb-java</artifactId>
		<version>1.5</version>
	</dependency>
	<dependency>
		<groupId>com.github.docker-java</groupId>
		<artifactId>docker-java</artifactId>
		<version>0.10.5</version>
	</dependency>
	<!--  KairosDB -->
  <dependency>
  	<groupId>org.kairosdb</groupId>
  	<artifactId>client</artifactId>

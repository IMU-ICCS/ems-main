        <details key="cardFrom_To_Conformance" value="&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;(cardFrom &lt;> null implies (cardFrom.cardinalityMin >= from.featureCardinality.cardinalityMin and cardFrom.cardinalityMax &lt;= from.featureCardinality.cardinalityMax)) &#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;and &#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;(cardTo &lt;> null implies (cardTo.cardinalityMin >= to.featureCardinality.cardinalityMin and cardTo.cardinalityMax &lt;= to.featureCardinality.cardinalityMax))"/>
      </eAnnotations>

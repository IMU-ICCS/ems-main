        <details key="correct_service_reference_and_name_SSType" value="&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;/* concrete service only at VM level, PaaS needs to be covered also */&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;if (serviceReference.oclIsTypeOf(camel::deployment::Component)) then serviceName = serviceReference.oclAsType(camel::deployment::Component).name &#xA;&#x9;&#x9;&#x9;&#x9;&#x9;else &#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;if (serviceReference.oclIsTypeOf(camel::VMType)) then serviceName = serviceReference.oclAsType(camel::VMType).name&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;else false endif&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;endif"/>

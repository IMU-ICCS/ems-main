      <details key="correct_action_type" value="&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;if (self.oclIsTypeOf(camel::scalability::ScalingAction)) then (self.type = ActionType::SCALE_IN or self.type = ActionType::SCALE_OUT or self.type = ActionType::SCALE_UP or self.type = ActionType::SCALE_DOWN) &#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;else not(self.type = ActionType::SCALE_IN or self.type = ActionType::SCALE_OUT or self.type = ActionType::SCALE_UP or self.type = ActionType::SCALE_DOWN) endif"/>

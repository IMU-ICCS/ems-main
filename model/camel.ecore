    <eClassifiers xsi:type="ecore:EClass" name="ScalabilityRule">
      <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
        <details key="constraints" value="Scal_Rule_Horiz_Policy_Count Scal_Rule_Vert_Policy_Correct_Vals Scal_Rule_No_Conficting_Policies"/>

          <details key="body" value="&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;if (type &lt;> null) then&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;if (type.oclIsTypeOf(Range)) then&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;if (type.oclAsType(Range).primitiveType = TypeEnum::IntType) then&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;values->exists(p | p.oclAsType(IntValue).value = v.oclAsType(IntValue).value)&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;else&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;if (type.oclAsType(Range).primitiveType = TypeEnum::FloatType) then&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;values->exists(p | p.oclAsType(FloatValue).value = v.oclAsType(FloatValue).value)&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;else &#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;values->exists(p | p.oclAsType(DoubleValue).value = v.oclAsType(DoubleValue).value)&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;endif&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;endif&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;else &#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;if (type.oclIsTypeOf(RangeUnion)) then&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;if (type.oclAsType(RangeUnion).primitiveType = TypeEnum::IntType) then&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;values->exists(p | p.oclAsType(IntValue).value = v.oclAsType(IntValue).value)&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;else&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;if (type.oclAsType(RangeUnion).primitiveType = TypeEnum::FloatType) then&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;values->exists(p | p.oclAsType(FloatValue).value = v.oclAsType(FloatValue).value)&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;else &#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;values->exists(p | p.oclAsType(DoubleValue).value = v.oclAsType(DoubleValue).value)&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;endif&#xA;&#x9;&#x9;&#x9;&#x9;&#x
        <details key="Actions_Allowed" value="&#xA;&#x9;&#x9;&#x9;(self.onResource.oclIsTypeOf(ResourceGroup) and self.onResource.oclAsType(ResourceGroup).allowsActionsOnResources(self.toAction)) or (not(self.onResource.oclIsTypeOf(ResourceGroup)) and self.onResource.oclAsType(Resource).allowsActions(self.toAction))"/>
      </eAnnotations>
      <eOperations name="checkStartEndDates" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="body" value="System.out.println(&quot;CHECKING Permission_Start_Before_End: &quot; + this + &quot; &quot; + this.getStart() + &quot; &quot; + this.getEnd()); java.util.Date date1 = this.getStart(); java.util.Date date2 = this.getEnd(); if (date1 == null || date2 == null || (date1 != null &amp;&amp; date2 != null &amp;&amp; date1.before(date2))) return Boolean.TRUE; return Boolean.FALSE;"/>
        </eAnnotations>
        <eParameters name="this" lowerBound="1" eType="#//organisation/Permission"/>
